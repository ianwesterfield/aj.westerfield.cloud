<Application x:Class="FunnelCloud.Tray.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown"
             Startup="Application_Startup">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ui:ThemesDictionary Theme="Dark" />
        <ui:ControlsDictionary />
      </ResourceDictionary.MergedDictionaries>
      
      <tb:TaskbarIcon x:Key="TrayIcon"
                      IconSource="/Assets/tray-icon.ico"
                      ToolTipText="FunnelCloud"
                      LeftClickCommand="{Binding ShowFlyoutCommand}"
                      DoubleClickCommand="{Binding ShowFlyoutCommand}">
        <tb:TaskbarIcon.ContextMenu>
          <ContextMenu>
            <ui:MenuItem Header="Show Events"
                         Icon="{ui:SymbolIcon Alert24}"
                         Command="{Binding ShowFlyoutCommand}"/>
            <Separator/>
            <ui:MenuItem Header="Exit"
                         Icon="{ui:SymbolIcon Dismiss24}"
                         Command="{Binding ExitCommand}"/>
          </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
      </tb:TaskbarIcon>
    </ResourceDictionary>
  </Application.Resources>
</Application>
