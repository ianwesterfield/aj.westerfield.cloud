# =============================================================================
# AJ Docker Configuration
# =============================================================================

# Docker Hub username for base images (default: AJ for local builds)
BASE_REGISTRY=ianwesterfield

# =============================================================================
# Workspace Configuration
# =============================================================================

# Host path to mount as /workspace in orchestrator/executor containers
# This gives AJ access to your local code directories
# TODO: Udpate to use sessional workspace paths
HOST_WORKSPACE_PATH=/mnt/c/Code/aj.westerfield.cloud/

# =============================================================================
# Resource Limits
# =============================================================================

# Max parallel tasks for orchestrator
MAX_PARALLEL_TASKS=20

# =============================================================================
# FunnelCloud Agent Discovery
# =============================================================================
#
# For WSL2: Local agent is the gateway IP (run: cat /etc/resolv.conf | grep nameserver)
# For native Linux: Use the IP of the machine running the local agent
# Gossip seed: ONE reachable agent IP to bootstrap cross-subnet discovery

# =============================================================================
# LLM (llama.cpp llama-server on WSL host)
# =============================================================================
# Primary inference: local RTX 4090 serving AJ-DeepSeek-R1-Qwen-32B Q4_K_M.
# Start via: bash scripts/start-llama-server.sh
LLM_BASE_URL=http://localhost:8081
LLM_MODEL=ajr1-32b

# (Legacy — kept so older images still resolve. Ignored when LLM_* are set.)
# Remote Ollama (rented Blackwell), only used if you flip LLM_BASE_URL back.
# OLLAMA_REMOTE_URL=http://72.19.32.135:50862
# OLLAMA_MODEL=aj:v3-q8

# =============================================================================# Hugging Face Configuration
# =============================================================================
# You'll need a token from Hugging Face to access their model hub. You can create an account and generate a token at https://huggingface.co/settings/tokens
