# AJ Docker Compose Environment Variables
# Copy this file to .env and customize for your setup.

# =============================================================================
# LOCAL LLM (llama.cpp llama-server) — PRIMARY INFERENCE RUNTIME
# =============================================================================
# llama-server runs natively on the WSL2 host (NOT in docker) so it can use
# CUDA on the RTX 4090 directly. Start it via:
#
#   sudo bash scripts/build_llamacpp.sh          # one-time build
#   bash scripts/start-llama-server.sh           # launch in tmux session "llm"
#
# or install the systemd unit in scripts/llama-server.service.
#
# Default model: AJ-DeepSeek-R1-Qwen-32B v2.1.0 Q4_K_M (18.5 GB).

LLM_BASE_URL=http://localhost:8081
LLM_MODEL=ajr1-32b

# Legacy aliases — read as fallbacks by the services for backwards
# compatibility. New config should prefer the LLM_* vars above.
# OLLAMA_BASE_URL=http://localhost:8081
# OLLAMA_MODEL=ajr1-32b

# =============================================================================
# REMOTE INFERENCE (optional GPU rental)
# =============================================================================
# To point at a rented remote GPU instead of the local llama-server, set
# LLM_BASE_URL above to the remote endpoint. The remote must expose an
# OpenAI-compatible /v1/chat/completions endpoint (llama-server, vLLM, TGI,
# Ollama, etc.).
#
# Example (llama-server on rented host):
#   LLM_BASE_URL=http://REMOTE_IP:8081
#   LLM_MODEL=ajr1-32b

# =============================================================================
# BASE IMAGES
# =============================================================================
# Docker registry for pre-built base images
# BASE_REGISTRY=ianwesterfield
