# AJ Docker Compose Environment Variables
# Copy this file to .env and customize for your setup

# =============================================================================
# REMOTE OLLAMA (GPU Rental)
# =============================================================================
# When using a remote GPU (RunPod, Vast.ai, Lambda Labs, etc.):
# 1. Set up Ollama on the remote box: curl -fsSL https://ollama.com/install.sh | sh
# 2. Pull your model: ollama pull llama3.1:70b (or qwen2.5:72b)
# 3. Start Ollama bound to all interfaces: OLLAMA_HOST=0.0.0.0 ollama serve
# 4. Set the URL below to point to your remote GPU

# Uncomment and set to your remote GPU's IP/hostname
# OLLAMA_REMOTE_URL=http://192.168.1.100:11434

# Model to use (change when switching to larger model on remote GPU)
# OLLAMA_MODEL=llama3.1:70b
# OLLAMA_MODEL=qwen2.5:72b
# OLLAMA_MODEL=command-r-plus

# =============================================================================
# LOCAL DEFAULTS (when not using remote GPU)
# =============================================================================
# Leave OLLAMA_REMOTE_URL unset to use local Ollama container
# Default model is r1-distill-aj:32b-8k (Manchurian Candidate trained)

# =============================================================================
# BASE IMAGES
# =============================================================================
# Docker registry for pre-built base images
# BASE_REGISTRY=ianwesterfield
